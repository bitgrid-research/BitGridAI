# BitGridAI — Umgebungsvariablen
# Kopieren nach .env und mit eigenen Werten befüllen
# .env wird NICHT ins Repository eingecheckt

# ─── Umbrel / Home Assistant ─────────────────────────────────────────────────
UMBREL_HOST=<IP-DES-UMBREL>         
UMBREL_USER=umbrel

# ─── Auth & Tokens ───────────────────────────────────────────────────────────
# Home Assistant Long-Lived Access Token
# Erstellen unter: HA → Profil → Langlebige Zugriffstoken
BITGRIDAI_HA_TOKEN=

# Stitch API Key (falls genutzt)
STITCH_API_KEY=

# ─── SMA Solar (Wechselrichter + Batterie) ───────────────────────────────────
SMA_HOST=<IP-DES-SMA-WECHSELRICHTERS>
SMA_USER=user
SMA_PASSWORD=

# ─── MQTT-Broker ─────────────────────────────────────────────────────────────
MQTT_HOST=<IP-DES-MQTT-BROKERS>
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=
MQTT_LOCATION=home

# ─── Mining Pool (generisch) ─────────────────────────────────────────────────
# F2Pool:   POOL_API_URL=https://api.f2pool.com/bitcoin/<username>
# Braiins:  POOL_API_URL=https://pool.braiins.com/api/v1/...
POOL_API_URL=https://api.f2pool.com/bitcoin/<username>
POOL_API_KEY=<READ-ONLY-KEY>         # F2Pool: Sharing-Link Key aus f2pool.com/mining-user/...

# ─── Bitcoin Miner (Canaan Avalon Q) ─────────────────────────────────────────
# Format: IP:PORT:ID,IP:PORT:ID (Komma-getrennte Liste)
MINER_HOSTS=<MINER1-IP>:4028:001,<MINER2-IP>:4028:002
# Einzelne Miner-IPs (für generate_ha_packages.sh)
MINER1_IP=<MINER1-IP>
MINER2_IP=<MINER2-IP>
MINER_API_PORT=4028
CANAAN_POLL_INTERVAL_SEC=30
MINER_TEMP_WARN_C=80
MINER_TEMP_STOP_C=85                 # muss mit rules.yaml r3.max_chip_temp_c übereinstimmen

# ─── HA Docker Proxy (netsh portproxy Workaround) ────────────────────────────
# Wird benötigt damit HA-Docker-Container die Miner-API erreichen kann
# Windows-Host-IP (IPv4, kein 127.0.0.1)
HA_PROXY_IP=<IP-DES-WINDOWS-HOSTS>
# Proxy-Ports auf dem Windows-Host (beliebig, müssen frei sein)
HA_MINER1_PROXY_PORT=14028
HA_MINER2_PROXY_PORT=24028

# ─── Modbus TCP (Batterie-BMS) ────────────────────────────────────────────────
MODBUS_HOST=<IP-DES-MODBUS-GERAETS>
MODBUS_PORT=502
MODBUS_UNIT_ID=1
MODBUS_SOC_REG=0x0000               # Pylontech=0x0000, BYD=0x0100, Victron=840
MODBUS_SOC_SCALE=1.0                # Pylontech=1.0, BYD=0.1, Victron=0.1
MODBUS_POLL_SEC=10

# ─── Shelly ──────────────────────────────────────────────────────────────────
# Shelly EM / 3EM — Netzzähler
SHELLY_EM_DEVICE_ID=shellyem-XXXXXX # von Shelly-Webinterface ablesen
SHELLY_EM_CHANNELS=1                # 1 = Shelly EM, 3 = Shelly 3EM
# Shelly Plug S — Relay-Steuerung
SHELLY_DEVICE_ID=shellyplug-s-XXXXXX

# ─── Bitaxe ──────────────────────────────────────────────────────────────────
BITAXE_HOST=<IP-DES-BITAXE>
BITAXE_PORT=80
BITAXE_POLL_INTERVAL_SEC=10
# BITAXE_SHELLY_DEVICE_ID=shellyplug-s-YYYYYY

# ─── PV-Wechselrichter (generisch via MQTT) ──────────────────────────────────
# ESPHome-Bridge, Home Assistant MQTT, Solarman-to-MQTT etc.
PV_MQTT_TOPIC=bitgrid/home/pv_inverter/power_w
PV_MQTT_SCALE=1.0                   # 1.0 wenn Topic in W, 1000.0 wenn in kW

# ─── Strompreis-API ──────────────────────────────────────────────────────────
PRICE_SOURCE=awattar                # awattar (kein Key) oder entsoe (Key nötig)
PRICE_POLL_MIN=60
PRICE_VAT_FACTOR=1.19               # MwSt: 1.19 DE, 1.20 AT
AWATTAR_COUNTRY=de                  # de oder at
# ENTSOE_TOKEN=                     # Token von transparency.entsoe.eu
# ENTSOE_AREA=10Y1001A1001A82H      # DE=10Y1001A1001A82H, AT=10YAT-APG------L

# ─── PV-Prognose (forecast.solar) ────────────────────────────────────────────
FORECAST_LAT=<BREITENGRAD>          # z.B. 48.1
FORECAST_LON=<LAENGENGRAD>          # z.B. 11.6
FORECAST_DEC=35                     # Dachneigung (Grad)
FORECAST_AZ=0                       # Azimut: 0=Süd, -90=Ost, 90=West
FORECAST_KWP=10.0                   # Installierte Peakleistung (kWp)
FORECAST_POLL_MIN=60
FORECAST_HORIZON_MIN=60             # Wie weit R4 vorausschaut (Minuten)

# ─── Anwendung ────────────────────────────────────────────────────────────────
DB_PATH=data/bitgrid.db
API_PORT=8080
API_TOKEN=change-me
LOG_LEVEL=INFO

# ─── Simulation & Entwicklung ────────────────────────────────────────────────
# SIMULATION_MODE=true
# REPLAY_MODE=false
RECORDER_TOPIC=#                    # Alle Topics aufzeichnen
RECORDER_OUT=recordings/session.jsonl

# BitGridAI — Umgebungsvariablen
# Kopieren nach .env und mit eigenen Werten befüllen
# .env wird NICHT ins Repository eingecheckt

# MQTT-Broker
MQTT_HOST=192.168.1.10
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=

# MQTT-Topic-Präfix
MQTT_LOCATION=home

# PV-Wechselrichter (MqttInverterAdapter — generisch via MQTT)
# ESPHome-Bridge, Home Assistant MQTT, Solarman-to-MQTT etc.
PV_MQTT_TOPIC=bitgrid/home/pv_inverter/power_w
PV_MQTT_SCALE=1.0                    # 1.0 wenn Topic in W, 1000.0 wenn in kW

# Shelly EM / 3EM — Netzzähler (grid_import_w, grid_export_w)
SHELLY_EM_DEVICE_ID=shellyem-XXXXXX  # von Shelly-Webinterface ablesen
SHELLY_EM_CHANNELS=1                 # 1 = Shelly EM, 3 = Shelly 3EM

# Modbus TCP — Batterie-BMS (battery_soc_pct)
MODBUS_HOST=192.168.1.100
MODBUS_PORT=502
MODBUS_SOC_REG=0x0000               # Register-Adresse: Pylontech=0x0000, BYD=0x0100, Victron=840
MODBUS_SOC_SCALE=1.0                # Skalierung: Pylontech=1.0, BYD=0.1, Victron=0.1
MODBUS_UNIT_ID=1                    # Modbus Unit-ID (meist 1)
MODBUS_POLL_SEC=10

# Bitcoin Miner — Canaan Avalon Q 90TH 1674W
MINER_HOST=192.168.1.50              # IP-Adresse des Canaan Miners
MINER_API_PORT=4028                  # CGMiner-API Port (Standard: 4028, kein Login nötig)
CANAAN_POLL_INTERVAL_SEC=10          # Poll-Intervall CGMiner API (Sekunden)
MINER_TEMP_WARN_C=80                 # Warnschwelle Temperatur (°C)
MINER_TEMP_STOP_C=85                 # Stop-Schwelle (°C) — muss mit rules.yaml r3.max_chip_temp_c übereinstimmen

# Shelly Plug S — Relay-Steuerung und Leistungsmessung
# Device-ID steht auf dem Shelly-Gerät oder im Shelly-Webinterface (Einstellungen → Gerätename)
# Beispiel: shellyplug-s-A1B2C3
SHELLY_DEVICE_ID=shellyplug-s-XXXXXX

# Bitaxe — AxeOS HTTP-API (kein Login, kein spezielles Protokoll)
BITAXE_HOST=192.168.1.60             # IP-Adresse des Bitaxe
BITAXE_PORT=80
BITAXE_POLL_INTERVAL_SEC=10
# Optional: eigener Shelly für Bitaxe (bei 15W meist nicht nötig)
# BITAXE_SHELLY_DEVICE_ID=shellyplug-s-YYYYYY

# Datenbank
DB_PATH=data/bitgrid.db

# Logging
LOG_LEVEL=INFO

# API
API_PORT=8080
API_TOKEN=change-me

# Strompreis-API (PriceAdapter → energy_price_ct_kwh)
PRICE_SOURCE=awattar              # awattar (kein Key) oder entsoe (Key nötig)
PRICE_POLL_MIN=60
PRICE_VAT_FACTOR=1.19            # MwSt: 1.19 DE, 1.20 AT
AWATTAR_COUNTRY=de               # de oder at
# ENTSOE_TOKEN=                  # Token von transparency.entsoe.eu (für PRICE_SOURCE=entsoe)
# ENTSOE_AREA=10Y1001A1001A82H   # Preisgebiet: 10Y1001A1001A82H=DE, 10YAT-APG------L=AT

# PV-Prognose (ForecastAdapter → pv_forecast_kw)
# forecast.solar — kostenlos, kein Key, max 12 Anfragen/Stunde
FORECAST_LAT=48.1                # Breitengrad (eigenen eintragen!)
FORECAST_LON=11.6                # Längengrad
FORECAST_DEC=35                  # Dachneigung (Grad)
FORECAST_AZ=0                    # Azimut: 0=Süd, -90=Ost, 90=West
FORECAST_KWP=10.0                # Installierte Peakleistung (kWp)
FORECAST_POLL_MIN=60
FORECAST_HORIZON_MIN=60          # Wie weit R4 vorausschaut (Minuten)

# MQTT Recorder (Simulation)
RECORDER_TOPIC=#                 # Alle Topics aufzeichnen
RECORDER_OUT=recordings/session.jsonl

# Feature-Flags (Overrides für Entwicklung)
# SIMULATION_MODE=true
# REPLAY_MODE=false
